# в”Җв”Җ Python в”Җв”Җ
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# в”Җв”Җ Build artifacts в”Җв”Җ
build/
dist/
*.spec
*.egg

# в”Җв”Җ PyInstaller bootloader output в”Җв”Җ
# The .exe is shipped pre-built for end users;
# uncomment the next line if you want source-only distribution
# мӢӨн–ү/CleanMeshStudio.exe

# в”Җв”Җ Logs / runtime в”Җв”Җ
*.log
мӢӨн–ү/CleanMeshStudio.log
мӢӨн–ү/_onedrive_backup.txt

# в”Җв”Җ Windows shortcuts (machine-specific absolute paths) в”Җв”Җ
*.lnk

# в”Җв”Җ OS junk в”Җв”Җ
.DS_Store
Thumbs.db
desktop.ini

# в”Җв”Җ Editor / IDE в”Җв”Җ
.vscode/
.idea/
*.swp
*~

# в”Җв”Җ Large binaries / models (handled by upstream installs) в”Җв”Җ
*.safetensors
*.bin
*.ckpt
*.pt
*.onnx

# в”Җв”Җ Generated docs (auto-built from build_docs.py) в”Җв”Җ
# Uncomment if you want to ship pre-built docs:
# CleanMesh_кё°мҲ л¬ём„ң.docx
# CleanMesh_л§Өлүҙм–ј.pptx

# в”Җв”Җ Local secrets / env в”Җв”Җ
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# в”Җв”Җ TRELLIS / SAM2 weights (downloaded at install time) в”Җв”Җ
trellis_wsl/checkpoints/
trellis_wsl/_workdir/
trellis_wsl/*.log
